print('My Simple Bill Splitter Tool')

bill_cost = float(input('Enter your bill cost: '))

tip_amount = int(input('Enter your tip amount: '))

number_of_friends = int(input('Enter number of friends splitting the bill: '))

decimal_tip = tip_amount/100

total_tip_amount = bill_cost * decimal_tip

grand_total = bill_cost + total_tip_amount

split_amount_per_person = grand_total / number_of_friends

final_bill_cost = round(bill_cost, 2)

final_total_tip_amount = round(total_tip_amount, 2)

final_grand_total = round(grand_total, 2)

final_split_amount_per_person = round(split_amount_per_person, 2)

print('Final Bill Breakdown')

print(final_bill_cost)

print(final_total_tip_amount)

print(final_grand_total)

print(f'Each person owes: {final_split_amount_per_person}')
